DEBUG=true
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/catalog_db
AUTH_SERVICE_URL=http://auth-service:8001
OPEN_LIBRARY_URL=https://openlibrary.org
GOOGLE_BOOKS_URL=https://www.googleapis.com/books/v1
ISBN_CACHE_TTL_DAYS=30

# Observability (ADR-012) — traces/metrics shipped to a local Grafana Alloy
# collector (see jinbocho-infrastructure-*/docker/config.alloy), which forwards
# to Grafana Cloud. Leave OTEL_ENABLED=false if you don't run the "observability"
# Compose profile — the service behaves identically either way.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4318
